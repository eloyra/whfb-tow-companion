%cabeceras y pies de página
\usepackage{vmargin}
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhfoffset{20pt}
\renewcommand{\headrulewidth}{0.0pt}
% El título del TFE puede ser largo y ocupar varias líneas en la cabecera
% (normativa UNIR, apdo. 1.3: nombre del estudiante + título del TFE en
% TODAS las páginas). Se reserva suficiente altura y se reduce ligeramente
% el tamaño de letra de la cabecera para evitar que se solape con el cuerpo.
\setlength{\headheight}{40pt}%

\renewcommand{\maketitle}{\creaportada}

\renewcommand{\baselinestretch}{1.5}



\usepackage{etoolbox}
\patchcmd{\chapter}{\if@openright\cleardoublepage\else\clearpage\fi}{\if@openright\clearpage\else\clearpage\fi}{}{}

% Normativa UNIR (apdo. 1.3): el encabezado debe aparecer en TODAS las
% páginas. Por defecto, book.cls aplica \thispagestyle{plain} a la primera
% página de cada capítulo, lo que oculta el \rhead en esa página. Forzamos
% el estilo "fancy" también ahí.
\patchcmd{\chapter}{\thispagestyle{plain}}{\thispagestyle{fancy}}{}{}



%hiper-referencias
\usepackage{hyperref}


%
%
%
\definecolor{azulunir}{rgb}{0,0.59,0.80}

\newcommand\director[1]{\def\@director{#1}}
\newcommand\nombreciudad[1]{\def\@nombreciudad{#1}}
\newcommand\titulacion[1]{\def\@titulacion{#1}}
\director{}
\nombreciudad{}

% NOTA TÉCNICA: \thetitle (paquete titling) entra en conflicto con la
% redefinición de \title que hace hyperref, dejando \thetitle vacío o con
% contenido incorrecto en el cuerpo del documento. Para mostrar el título
% del TFE en la cabecera de forma fiable (normativa UNIR, apdo. 1.3) se
% define aquí una macro independiente, \tfetitulo, que se debe rellenar
% con \tfetitulo{...} en el documento principal (ver plantilla.tex).
\newcommand\tfetitulo[1]{\def\@tfetitulo{#1}}
\tfetitulo{}

% NOTA TÉCNICA (corrección 2026-06-23): el valor original de -4cm empujaba
% el título del capítulo demasiado lejos del encabezado, generando un hueco
% visual excesivo e inconsistente entre páginas (capítulos numerados vs.
% \tableofcontents, títulos de una vs. dos líneas). -2.5cm da un equilibrio
% visual estable verificado en Cap. 1 (título corto), Cap. 5 (título a dos
% líneas) e Índice de Contenidos (capítulo no numerado).
\titleformat{\chapter}[hang]{\vspace{-2.5cm}\Huge\bfseries\color{azulunir}}{\thechapter. }{0pt}{\Huge\bfseries}



