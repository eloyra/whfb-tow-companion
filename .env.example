# Copy to .env and fill in values. Never commit .env.

# LLM provider — set one
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM config
LLM_PROVIDER=openai          # openai | anthropic | local
LLM_MODEL=gpt-4o
LOCAL_LLM_BASE_URL=          # e.g. http://localhost:11434 for Ollama

# Embeddings (same model must be used at ingestion AND query time — see ADR-0001)
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# Neo4j (graph + vector store — see ADR-0001, ADR-0005)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Graph build
GRAPH_WIPE_ON_BUILD=false       # set to true for a clean rebuild from scratch

# Embeddings
EMBEDDING_DIM=768
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu            # cpu | cuda | mps
VECTOR_INDEX_SIMILARITY=cosine

# Scraping
SCRAPE_DELAY_SECONDS=1.0
SCRAPE_BASE_URL=https://tow.whfb.app

# API
API_HOST=0.0.0.0
API_PORT=8000